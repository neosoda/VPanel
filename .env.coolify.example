# ============================================================
# Vpanel - Coolify deployment variables
# ============================================================

# ------------------------------------------------------------
# Build-time variables (Docker build args / Vite)
# ------------------------------------------------------------
# IMPORTANT: these values are baked into the frontend bundle.
VITE_APP_MODE=production
VITE_APP_BASE=/
VITE_APP_URL=https://vpanel.example.com/
VITE_APP_API_URL=/api/
VITE_USE_AUTH=false

# Optional build metadata values used by Vite plugins
VITE_APP_HOSTNAME=https://vpanel.example.com
VITE_APP_LOCALE=fr-FR

# If you deploy with docker-compose.prod.yml (Compose mode),
# mirror the same values with COOLIFY_ prefixes:
COOLIFY_VITE_APP_MODE=production
COOLIFY_VITE_APP_BASE=/
COOLIFY_VITE_APP_HOSTNAME=https://vpanel.example.com
COOLIFY_VITE_APP_URL=https://vpanel.example.com/
COOLIFY_VITE_APP_API_URL=/api/
COOLIFY_VITE_USE_AUTH=false

# ------------------------------------------------------------
# Runtime variables (container environment)
# ------------------------------------------------------------
PHP_APP_MODE=production
PHP_DEBUG=false

# Hostname allowed by backend referer checks (no path)
APP_HOSTNAME=vpanel.example.com

# Persistent SQLite path (mount a Coolify volume to /app/public/data)
SQLITE_DB_PATH=/app/public/data/vpanel.sqlite

# PHP-FPM pool tuning
PHP_FPM_PM_MAX_CHILDREN=20
PHP_FPM_PM_START_SERVERS=4
PHP_FPM_PM_MIN_SPARE_SERVERS=2
PHP_FPM_PM_MAX_SPARE_SERVERS=10

# ------------------------------------------------------------
# Coolify notes
# ------------------------------------------------------------
# - Internal container port: 8080
# - Health endpoint: /api/health.php
# - Required persistent volume mount: /app/public/data
